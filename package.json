{
  "name": "mac-jarvis",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Web holographic spatial UI: Three.js + MediaPipe hand fists, GLB holograms, camera-locked viewport",
  "keywords": [
    "react",
    "three.js",
    "react-three-fiber",
    "mediapipe",
    "hand-tracking",
    "vite",
    "typescript",
    "zustand"
  ],
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.34",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/postprocessing": "^3.0.4",
    "@types/three": "^0.183.1",
    "postprocessing": "^6.39.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "three": "^0.183.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.8",
    "vitest": "^3.2.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/VenkataVardineni/mac-jarvis-holographic.git"
  },
  "homepage": "https://github.com/VenkataVardineni/mac-jarvis-holographic#readme",
  "bugs": {
    "url": "https://github.com/VenkataVardineni/mac-jarvis-holographic/issues"
  },
  "engines": {
    "node": ">=20"
  }
}
